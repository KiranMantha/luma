# API server port
PORT=3002

# SQLite DB file path (relative to apps/api)
DB_FILE=./cms.db

# CORS origins for API (comma-separated)
CORS_ORIGINS=http://localhost:3000

# Directory where page model JSON files are written.
# Points to CMS public/pages so Next.js serves them as static assets.
PUBLIC_PAGES_DIR=../cms/public/pages